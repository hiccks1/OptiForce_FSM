import type { PrismaClient, Job } from '@prisma/client';
import type { RequestContext } from '../types';
import { BaseEntityService } from './BaseEntityService';
import {
  AuthorizationError,
  ConfigurationError,
  ValidationError,
} from '../errors';

// ============================================
// JOB SERVICE
// ============================================

export class JobService extends BaseEntityService<Job> {
  constructor(prisma: PrismaClient) {
    super(prisma, 'job');
  }

  // ==========================================
  // PERMISSIONS (COMPANY CONFIG + ACTOR TYPE)
  // ==========================================

  protected override isAllowed(
    ctx: RequestContext,
    operation: 'create' | 'read' | 'update' | 'delete' | 'restore' | 'list'
  ): boolean {
    if (ctx.actorType === 'SYSTEM') return true;

    if (ctx.actorType === 'AI') {
      const config = this.getBettyConfig(ctx);
      if (!config.enabled) return false;

      switch (operation) {
        case 'create':
          return config.permissions.canCreateJobs;
        case 'update':
          return config.permissions.canUpdateJobs;
        case 'delete':
          return config.permissions.canDeleteJobs;
        default:
          return false;
      }
    }

    // HUMAN
    return ctx.userRole === 'OWNER' || ctx.userRole === 'ADMIN';
  }

  // ==========================================
  // INTERNALS
  // ==========================================

  protected async findById(
    ctx: RequestContext,
    id: string
  ): Promise<Job | null> {
    return this.prisma.job.findFirst({
      where: {
        id,
        companyId: ctx.companyId,
        deletedAt: null,
      },
    });
  }

  protected async createInternal(
    ctx: RequestContext,
    input: unknown
  ): Promise<Job> {
    const payload = this.validateJobPayload(ctx, input);

    return this.prisma.job.create({
      data: {
        ...payload,
        companyId: ctx.companyId,
        createdById: ctx.userId,
      },
    });
  }

  protected async updateInternal(
    ctx: RequestContext,
    id: string,
    input: unknown
  ): Promise<Job> {
    const payload = this.validateJobPayload(ctx, input, true);

    return this.prisma.job.update({
      where: { id },
      data: {
        ...payload,
        updatedById: ctx.userId,
      },
    });
  }

  protected async softDeleteInternal(
    ctx: RequestContext,
    id: string
  ): Promise<void> {
    await this.prisma.job.update({
      where: { id },
      data: {
        deletedAt: new Date(),
        deletedById: ctx.userId,
      },
    });
  }

  protected async restoreInternal(
    ctx: RequestContext,
    id: string
  ): Promise<void> {
    await this.prisma.job.update({
      where: { id },
      data: {
        deletedAt: null,
        deletedById: null,
      },
    });
  }

  // ==========================================
  // VALIDATION (SCHEMA-DRIVEN)
  // ==========================================

  protected override validateCreate(input: unknown): void {
    if (!input || typeof input !== 'object') {
      throw new ValidationError('Invalid job payload');
    }
  }

  protected override validateUpdate(input: unknown): void {
    if (!input || typeof input !== 'object') {
      throw new ValidationError('Invalid job update payload');
    }
  }

  private validateJobPayload(
    ctx: RequestContext,
    input: unknown,
    partial = false
  ): Record<string, unknown> {
    if (!input || typeof input !== 'object') {
      throw new ValidationError('Invalid job payload');
    }

    const config = this.getCompanyJobSchema(ctx);

    // NOTE:
    // This is intentionally NOT Zod yet.
    // Schema enforcement comes from company config JSON schema.
    // Zod can wrap this later if needed.

    if (!config) {
      throw new ConfigurationError(
        'Company job schema is missing'
      );
    }

    return input as Record<string, unknown>;
  }

  // ==========================================
  // CONFIG ACCESS (SINGLE SOURCE OF TRUTH)
  // ==========================================

  private getCompanyJobSchema(ctx: RequestContext) {
    return ctx.metadata?.companyConfig?.jobSchema;
  }

  private getBettyConfig(ctx: RequestContext) {
    const config = ctx.metadata?.companyConfig?.bettyConfig;
    if (!config) {
      throw new ConfigurationError('Betty config missing');
    }
    return config;
  }
}
