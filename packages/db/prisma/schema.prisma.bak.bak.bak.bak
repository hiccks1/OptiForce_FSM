// ============================================
// TENANT ROOT
// ============================================

model Company {
  id            String        @id @default(uuid())
  name          String
  subdomain     String        @unique
  profileType   ProfileType  @default(CLASSIC)

  config        CompanyConfig?
  subscription  Subscription?
  branding      CompanyBranding?

  accounts      Account[]
  users         User[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("companies")
}

enum ProfileType {
  CLASSIC
  MODERN
  AI_FIRST
  DATA_DRIVEN
  COMPLIANCE_HEAVY
  CUSTOM
}

// ============================================
// COMPANY CONFIG (SOURCE OF TRUTH)
// ============================================

model CompanyConfig {
  id          String   @id @default(uuid())
  companyId   String   @unique

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  bettyEnabled       Boolean @default(false)
  bettyPermissions   Json    @default("{}")

  modulesEnabled     Json    @default("{}")
  workflows          Json    @default("{}")
  uiSettings         Json    @default("{}")
  documentSettings   Json    @default("{}")
  complianceSettings Json    @default("{}")
  integrations       Json    @default("{}")
  analyticsSettings  Json    @default("{}")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("company_configs")
}

// ============================================
// SUBSCRIPTION & BILLING
// ============================================

model Subscription {
  id        String @id @default(uuid())
  companyId String @unique

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  plan      SubscriptionPlan
  status    SubStatus @default(TRIAL)

  limits        Json
  currentUsage Json

  trialEndsAt          DateTime?
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?

  stripeCustomerId     String?
  stripeSubscriptionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subscriptions")
}

enum SubscriptionPlan {
  TRIAL
  STARTER
  PROFESSIONAL
  ENTERPRISE
  CUSTOM
}

enum SubStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  PAUSED
}

// ============================================
// COMPANY BRANDING
// ============================================

model CompanyBranding {
  id        String @id @default(uuid())
  companyId String @unique

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  logoUrl        String?
  primaryColor   String @default("#1976d2")
  secondaryColor String @default("#dc004e")
  faviconUrl     String?

  emailHeaderUrl String?
  emailFooter    String? @db.Text

  invoiceTemplate   String? @db.Text
  estimateTemplate  String? @db.Text
  workOrderTemplate String? @db.Text

  customDomain String? @unique

  @@map("company_branding")
}

// ============================================
// USERS (STAFF)
// ============================================

model User {
  id        String   @id @default(uuid())
  companyId String

  email     String   @unique
  name      String
  role      UserRole
  isActive  Boolean  @default(true)

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  salesMade      Estimate[] @relation("Salesperson")
  ticketsCreated Job[]      @relation("CSRCreator")
  assignedVisits Visit[]    @relation("TechnicianAssignment")

  createdAt DateTime @default(now())

  @@map("users")
  @@index([companyId])
}

enum UserRole {
  ADMIN
  SALESMAN
  CSR
  TECHNICIAN
  DISPATCHER
}

// ============================================
// ACCOUNTS (CUSTOMERS / PROPERTIES)
// ============================================

model Account {
  id            String        @id @default(uuid())
  companyId     String

  accountNumber String        @unique
  status        AccountStatus @default(ACTIVE)
  type          AccountType   @default(RESIDENTIAL)
  taxExempt     Boolean       @default(false)

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customers      Customer[]
  addresses      Address[]
  contacts       Contact[]
  estimates      Estimate[]
  jobs           Job[]
  documents      Document[]
  maintenanceSchedules MaintenanceSchedule[]
  communications Communication[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@map("accounts")
  @@index([companyId])
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  CLOSED
}

enum AccountType {
  RESIDENTIAL
  COMMERCIAL
  PROPERTY_MANAGEMENT
}

// ============================================
// CUSTOMER
// ============================================

model Customer {
  id            String @id @default(uuid())
  accountId     String

  firstName     String
  lastName      String
  preferredName String?
  isPrimary     Boolean @default(false)
  relationship  String?

  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  portalUserId String? @unique
  portalUser   PortalUser? @relation(fields: [portalUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("customers")
  @@index([accountId])
}

// ============================================
// PORTAL USERS
// ============================================

model PortalUser {
  id           String @id @default(uuid())
  email        String @unique
  passwordHash String
  customer     Customer?
  lastLogin    DateTime?
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())

  @@map("portal_users")
}

// ============================================
// ESTIMATES
// ============================================

model Estimate {
  id          String @id @default(uuid())
  accountId   String
  salesmanId  String

  status      EstimateStatus @default(PENDING)
  totalAmount Decimal        @db.Decimal(10,2)
  discountApplied Decimal    @default(0)

  items Json

  account  Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  salesman User    @relation("Salesperson", fields: [salesmanId], references: [id])

  job       Job?
  followUps FollowUp[]

  createdAt DateTime @default(now())

  @@map("estimates")
  @@index([accountId])
}

enum EstimateStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

// ============================================
// JOBS & VISITS
// ============================================

model Job {
  id          String @id @default(uuid())
  estimateId  String? @unique
  accountId   String
  csrId       String

  title       String
  description String? @db.Text
  status      JobStatus @default(SCHEDULED)

  account  Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  estimate Estimate? @relation(fields: [estimateId], references: [id], onDelete: SetNull)
  csr      User @relation("CSRCreator", fields: [csrId], references: [id])

  visits    Visit[]
  documents Document[]
  notes     Note[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("jobs")
  @@index([accountId])
  @@index([status])
}

enum JobStatus {
  TICKET_CREATED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ============================================
// VISITS
// ============================================

model Visit {
  id           String @id @default(uuid())
  jobId        String
  technicianId String

  startTime DateTime
  endTime   DateTime
  summary   String? @db.Text

  job        Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  technician User @relation("TechnicianAssignment", fields: [technicianId], references: [id])

  @@map("visits")
  @@index([technicianId, startTime])
}

// ============================================
// DOCUMENTS & AI CHUNKS
// ============================================

model Document {
  id        String @id @default(uuid())
  accountId String
  jobId     String?

  name      String
  fileUrl   String
  fileType  String
  category  DocType

  processed Boolean @default(false)

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  job     Job?    @relation(fields: [jobId], references: [id], onDelete: SetNull)

  chunks DocumentChunk[]

  createdAt DateTime @default(now())

  @@map("documents")
  @@index([accountId])
}

enum DocType {
  CONTRACT
  RECEIPT
  INSTALL_PHOTO
  WARRANTY
  INVOICE
}

model DocumentChunk {
  id         String @id @default(uuid())
  documentId String

  content    String @db.Text
  embedding  Unsupported("vector(1536)")?
  chunkIndex Int
  metadata   Json?

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_chunks")
  @@index([documentId])
}

// ============================================
// AUDIT LOG (MANDATORY)
// ============================================

model AuditLog {
  id        String @id @default(uuid())
  companyId String

  userId    String?
  entityType String
  entityId   String
  action     String
  changes    Json?

  timestamp DateTime @default(now())

  @@map("audit_logs")
  @@index([companyId])
  @@index([entityType, entityId])
}

// ============================================
// CONVERSATIONS (AI MEMORY)
// ============================================

model Conversation {
  id        String @id @default(uuid())
  companyId String
  accountId String?

  messages Message[]

  startedAt DateTime @default(now())

  @@map("conversations")
  @@index([companyId])
}

model Message {
  id             String @id @default(uuid())
  conversationId String

  role     MessageRole
  content  String @db.Text
  metadata Json?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("messages")
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}
