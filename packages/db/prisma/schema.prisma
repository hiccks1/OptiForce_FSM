// ============================================
// FINAL PRISMA SCHEMA v5.3
// With Generated Columns Support
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  CSR
  FIELD
  CUSTOMER
  SYSTEM
}

enum ActorType {
  HUMAN
  SYSTEM
  AI
}

// ============================================
// COMPANY (TENANT ROOT)
// ============================================

model Company {
  id        String   @id @default(cuid())
  name      String
  subdomain String?  @unique
  
  users     User[]
  jobs      Job[]
  documents Document[]
  configs   CompanyConfig[]
  
  isDeleted Boolean  @default(false)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([isDeleted])
  @@map("companies")
}

// ============================================
// COMPANY CONFIG (SOURCE OF TRUTH)
// ============================================

model CompanyConfig {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  version   Int
  schema    Json     // Zod-validated runtime config
  /*
  Example structure:
  {
    "jobSchema": { ... },
    "bettyConfig": { ... },
    "hotPaths": {
      "job": ["status", "accountId", "estimatedValue"],
      "document": ["type", "uploadedBy"]
    },
    "workflows": { ... },
    "uiSettings": { ... }
  }
  */
  
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  createdBy String?
  
  @@unique([companyId, version])
  @@index([companyId, isActive])
  @@map("company_configs")
}

// ============================================
// USER
// ============================================

model User {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  email     String   @unique
  name      String?
  role      UserRole
  
  isDeleted Boolean  @default(false)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([companyId, role])
  @@index([isDeleted])
  @@map("users")
}

// ============================================
// JOB (CORE ENTITY)
// ============================================

model Job {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  // ========================================
  // JSONB DATA (ALL JOB DATA)
  // ========================================
  data      Json
  /*
  Complete job data structure:
  {
    "status": "SCHEDULED",
    "accountId": "acc_123",
    "estimatedValue": 1500.00,
    "scheduledDate": "2025-01-15T09:00:00Z",
    "technicianId": "user_456",
    "title": "AC Repair",
    "description": "Unit not cooling",
    "priority": "HIGH",
    "address": {
      "street": "123 Main St",
      "city": "Austin",
      "state": "TX",
      "zip": "78701"
    },
    "equipmentType": "Central AC",
    "customFields": {
      "preferredArrivalTime": "morning",
      "petOnPremises": true
    }
  }
  */
  
  // ========================================
  // NOTE: Generated columns will be added
  // dynamically per company via SQL:
  //
  // ALTER TABLE jobs 
  // ADD COLUMN status TEXT 
  // GENERATED ALWAYS AS (data->>'status') STORED;
  //
  // These are NOT in Prisma schema because:
  // 1. They're created at runtime per company
  // 2. Different companies have different columns
  // 3. Prisma doesn't need to know about them
  // ========================================
  
  // Standard fields
  isDeleted Boolean  @default(false)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([companyId])
  @@index([isDeleted])
  @@index([createdAt])
  @@map("jobs")
}

// ============================================
// DOCUMENT (MINIO-BACKED)
// ============================================

model Document {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  // ========================================
  // JSONB METADATA (ALL DOCUMENT DATA)
  // ========================================
  metadata  Json
  /*
  Document metadata structure:
  {
    "type": "INVOICE",
    "minioKey": "company_abc/jobs/job_123/invoice.pdf",
    "minioHash": "abc123def456",
    "originalName": "invoice.pdf",
    "mimeType": "application/pdf",
    "size": 1048576,
    "uploadedBy": "user_789",
    "uploadedAt": "2025-01-03T10:30:00Z",
    "relatedTo": {
      "entityType": "Job",
      "entityId": "job_123"
    },
    "processed": false,
    "tags": ["urgent", "customer-signed"]
  }
  */
  
  // ========================================
  // NOTE: Generated columns like 'type',
  // 'uploadedBy' can be added dynamically
  // per company needs via SQL
  // ========================================
  
  // Standard fields
  isDeleted Boolean  @default(false)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  
  @@index([companyId])
  @@index([isDeleted])
  @@index([createdAt])
  @@map("documents")
}

// ============================================
// AI ACTION AUDIT LOG
// ============================================

model AIActionLog {
  id        String   @id @default(cuid())
  companyId String
  
  actorId   String?
  actorType ActorType
  
  action    String   // "job.create", "document.upload", etc.
  input     Json     // What was requested
  outcome   Json     // What happened
  allowed   Boolean  // Was it permitted
  
  createdAt DateTime @default(now())
  
  @@index([companyId, actorType])
  @@index([companyId, createdAt])
  @@index([actorType, createdAt])
  @@map("ai_action_logs")
}

// ============================================
// HOT PATH METADATA (Track which columns exist)
// ============================================

model HotPathColumn {
  id        String   @id @default(cuid())
  companyId String
  
  tableName String   // "jobs", "documents"
  columnName String  // "status", "estimated_value"
  jsonPath  String   // "status", "estimatedValue"
  dataType  String   // "text", "numeric", "timestamptz"
  
  isIndexed Boolean  @default(false)
  indexName String?
  
  usage     Json?    // Query usage statistics
  /*
  {
    "queriesPerDay": 1500,
    "avgQueryTime": 12,
    "lastQueried": "2025-01-03T10:30:00Z"
  }
  */
  
  createdAt DateTime @default(now())
  createdBy String?
  
  @@unique([companyId, tableName, columnName])
  @@index([companyId, tableName])
  @@map("hot_path_columns")
}

