generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

////////////////////////
// ENUMS
////////////////////////

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  CSR
  FIELD
  CUSTOMER
  SYSTEM
}

enum ActorType {
  HUMAN
  SYSTEM
  AI
}

////////////////////////
// COMPANY (TENANT ROOT)
////////////////////////

model Company {
  id        String   @id @default(cuid())
  name      String

  users     User[]
  jobs      Job[]
  documents Document[]
  configs   CompanyConfig[]

  isDeleted Boolean  @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isDeleted])
}

////////////////////////
// COMPANY CONFIG
// (SOURCE OF TRUTH)
////////////////////////

model CompanyConfig {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])

  version   Int
  schema    Json     // Zod-validated runtime config
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  createdBy String?

  @@unique([companyId, version])
  @@index([companyId, isActive])
}

////////////////////////
// USER
////////////////////////

model User {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])

  email     String   @unique
  role      UserRole

  isDeleted Boolean  @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, role])
  @@index([isDeleted])
}

////////////////////////
// JOB
////////////////////////

model Job {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])

  status    String
  data      Json

  isDeleted Boolean  @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
  @@index([isDeleted])
}

////////////////////////
// DOCUMENT (MINIO BACKED)
////////////////////////

model Document {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])

  type      String
  metadata  Json    // MinIO object key, mime, size, checksum

  isDeleted Boolean  @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())

  @@index([companyId, type])
  @@index([isDeleted])
}

////////////////////////
// AI ACTION AUDIT LOG
////////////////////////

model AIActionLog {
  id        String   @id @default(cuid())
  companyId String
  actorId   String?
  actorType ActorType

  action    String
  input     Json
  outcome   Json
  allowed   Boolean

  createdAt DateTime @default(now())

  @@index([companyId, actorType])
}
